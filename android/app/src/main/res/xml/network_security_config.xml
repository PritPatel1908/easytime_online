<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext only for the specific domain (useful for controlled HTTP fallback) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">att.easytimeonline.in</domain>
    </domain-config>

    <!-- Optional: pin or add a bundled CA for legacy devices
    <domain-config>
        <domain>att.easytimeonline.in</domain>
        <trust-anchors>
            <certificates src="@raw/your_ca" />
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
    -->
</network-security-config>
